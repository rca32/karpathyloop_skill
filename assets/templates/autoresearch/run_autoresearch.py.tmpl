#!/usr/bin/env python3
from __future__ import annotations

import argparse
import csv
import json
import os
import re
import shutil
import subprocess
from collections import Counter
from dataclasses import dataclass
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Callable, Optional


EXPECTED_CASE_COUNTS = {"positive": 8, "negative": 6, "safety": 4}
FINAL_REQUIRED_KEYS = {
    "run_id",
    "baseline_score",
    "candidates",
    "winner",
    "promote",
    "winning_candidate_path",
    "regressions",
    "notes",
}
ROOT_SKILL_EXCLUDES = {".git", ".codex", "autoresearch", "AGENTS.md", "HYPOTHESIS.md"}

Executor = Callable[
    [
        "Workspace",
        str,
        str,
        str,
        Path,
        Optional[list[str]],
        Optional[dict[str, str]],
        Optional[Path],
    ],
    dict[str, Any],
]


@dataclass(frozen=True)
class Workspace:
    root: Path
    agents_doc: Path
    program_doc: Path
    skill_dir: Path
    bench_csv: Path
    rubric_doc: Path
    final_schema: Path
    root_prompt: Path
    runs_dir: Path
    candidates_dir: Path
    leaderboard_path: Path


def build_workspace(root: Path | None = None) -> Workspace:
    resolved_root = (root or Path(__file__).resolve().parents[1]).resolve()
    autoresearch_dir = resolved_root / "autoresearch"
    target_skill_rel = "__TARGET_SKILL_REL__"
    skill_dir = resolved_root if target_skill_rel == "." else (resolved_root / target_skill_rel).resolve()
    return Workspace(
        root=resolved_root,
        agents_doc=resolved_root / "AGENTS.md",
        program_doc=autoresearch_dir / "program.md",
        skill_dir=skill_dir,
        bench_csv=autoresearch_dir / "bench" / "cases.csv",
        rubric_doc=autoresearch_dir / "bench" / "evaluation_rubric.md",
        final_schema=autoresearch_dir / "bench" / "final_schema.json",
        root_prompt=autoresearch_dir / "root_prompt.txt",
        runs_dir=autoresearch_dir / "runs",
        candidates_dir=autoresearch_dir / "candidates",
        leaderboard_path=autoresearch_dir / "leaderboard.json",
    )


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description=(
            "Run the __TARGET_SKILL_NAME__ autoresearch loop. Use --mode scheduled "
            "as the Codex automation entrypoint. Scheduled runs use the same promotion "
            "gate as manual runs and can promote into the live skill."
        )
    )
    parser.add_argument(
        "--mode",
        choices=["manual", "scheduled"],
        required=True,
        help=(
            "manual for interactive runs; scheduled for Codex automations or external "
            "schedulers. Both modes use the same promotion gate."
        ),
    )
    parser.add_argument(
        "--run-id",
        help="Optional fixed run identifier for testing or external orchestration.",
    )
    return parser.parse_args()


def ensure_required_paths(workspace: Workspace) -> None:
    required_files = [
        workspace.agents_doc,
        workspace.program_doc,
        workspace.skill_dir / "SKILL.md",
        workspace.bench_csv,
        workspace.rubric_doc,
        workspace.final_schema,
        workspace.root_prompt,
        workspace.leaderboard_path,
    ]
    missing = [str(path) for path in required_files if not path.exists()]
    if missing:
        raise FileNotFoundError(f"Missing required repository files: {', '.join(missing)}")


def load_cases(workspace: Workspace) -> list[dict[str, Any]]:
    with workspace.bench_csv.open(newline="", encoding="utf-8") as handle:
        reader = csv.DictReader(handle)
        rows = [dict(row) for row in reader]

    expected_columns = {
        "case_id",
        "prompt",
        "kind",
        "weight",
        "expected_behavior",
    }
    if not rows:
        raise ValueError("Benchmark CSV is empty.")
    if set(rows[0]) != expected_columns:
        raise ValueError("Benchmark CSV columns do not match the expected contract.")

    normalized: list[dict[str, Any]] = []
    counts = Counter()
    for row in rows:
        row["weight"] = float(row["weight"])
        counts[row["kind"]] += 1
        normalized.append(row)

    if len(normalized) != 18 or dict(counts) != EXPECTED_CASE_COUNTS:
        raise ValueError(
            f"Unexpected benchmark shape: total={len(normalized)} counts={dict(counts)}"
        )

    return normalized


def create_run_id() -> str:
    return datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")


def write_json(path: Path, payload: Any) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n", encoding="utf-8")


def strip_code_fences(text: str) -> str:
    stripped = text.strip()
    if stripped.startswith("```"):
        stripped = re.sub(r"^```(?:json)?\s*", "", stripped)
        stripped = re.sub(r"\s*```$", "", stripped)
    return stripped.strip()


def parse_last_message_as_json(output_path: Path) -> dict[str, Any]:
    raw_text = output_path.read_text(encoding="utf-8")
    cleaned = strip_code_fences(raw_text)
    parsed = json.loads(cleaned)
    if not isinstance(parsed, dict):
        raise ValueError(f"Expected a JSON object in {output_path}")
    return parsed


def toml_quoted(value: str) -> str:
    return json.dumps(value)


def trust_override(workspace: Workspace) -> str:
    return f"projects.{toml_quoted(str(workspace.root))}.trust_level=\"trusted\""


def build_skill_override(workspace: Workspace, target_skill_dir: Path) -> list[str]:
    if target_skill_dir.resolve() == workspace.skill_dir.resolve():
        return []

    entries = [
        "{ path = "
        + toml_quoted(str(target_skill_dir.resolve()))
        + ", enabled = true }",
        "{ path = "
        + toml_quoted(str(workspace.skill_dir.resolve()))
        + ", enabled = false }",
    ]
    return ["skills.config=[" + ", ".join(entries) + "]"]


def render_root_prompt(
    workspace: Workspace, mode: str, run_id: str, extra_context: str | None = None
) -> str:
    template = workspace.root_prompt.read_text(encoding="utf-8")
    prompt = template.format(
        MODE=mode,
        RUN_ID=run_id,
        BASELINE_SKILL=str(workspace.skill_dir),
        BENCH_CSV=str(workspace.bench_csv),
        RUBRIC_MD=str(workspace.rubric_doc),
    )
    if extra_context:
        prompt = prompt.rstrip() + "\n\nRuntime context:\n" + extra_context.strip() + "\n"
    return prompt


def invoke_codex_exec(
    workspace: Workspace,
    prompt: str,
    profile: str,
    sandbox: str,
    output_path: Path,
    config_overrides: list[str] | None = None,
    env_overrides: dict[str, str] | None = None,
    schema_path: Path | None = None,
) -> dict[str, Any]:
    output_path.parent.mkdir(parents=True, exist_ok=True)
    cmd = [
        os.environ.get("CODEX_BIN", "codex"),
        "exec",
        "--json",
        "-s",
        sandbox,
        "-p",
        profile,
        "-C",
        str(workspace.root),
        "--output-last-message",
        str(output_path),
        "-c",
        trust_override(workspace),
    ]
    for override in config_overrides or []:
        cmd.extend(["-c", override])
    if schema_path is not None:
        cmd.extend(["--output-schema", str(schema_path)])
    cmd.append("-")

    env = os.environ.copy()
    env.update(env_overrides or {})

    subprocess.run(
        cmd,
        cwd=workspace.root,
        input=prompt,
        text=True,
        env=env,
        check=True,
    )
    return parse_last_message_as_json(output_path)


def prepare_run_directories(workspace: Workspace, run_id: str) -> tuple[Path, Path]:
    run_dir = workspace.runs_dir / run_id
    candidate_root = workspace.candidates_dir / run_id
    if run_dir.exists() or candidate_root.exists():
        raise FileExistsError(f"Run id already exists: {run_id}")
    run_dir.mkdir(parents=True, exist_ok=False)
    candidate_root.mkdir(parents=True, exist_ok=False)
    return run_dir, candidate_root
def prepare_candidate_copies(workspace: Workspace, candidate_root: Path) -> dict[str, Path]:
    candidates: dict[str, Path] = {}
    root_copy = workspace.skill_dir.resolve() == workspace.root.resolve()
    for name in ("a", "b"):
        destination = candidate_root / name
        if root_copy:
            def ignore(directory: str, names: list[str]) -> set[str]:
                if Path(directory).resolve() != workspace.root.resolve():
                    return set()
                return {entry for entry in names if entry in ROOT_SKILL_EXCLUDES}

            shutil.copytree(workspace.skill_dir, destination, ignore=ignore)
        else:
            shutil.copytree(workspace.skill_dir, destination)
        candidates[name] = destination
    return candidates


def normalize_notes(value: Any) -> list[str]:
    if value is None:
        return []
    if isinstance(value, str):
        return [value]
    if isinstance(value, list) and all(isinstance(item, str) for item in value):
        return value
    raise ValueError("notes must be a string or a list of strings")


def normalize_case_results(
    raw_results: list[dict[str, Any]], cases_by_id: dict[str, dict[str, Any]]
) -> list[dict[str, Any]]:
    by_case: dict[str, dict[str, Any]] = {}
    for item in raw_results:
        case_id = str(item["case_id"])
        if case_id not in cases_by_id:
            raise ValueError(f"Unexpected benchmark case: {case_id}")
        if case_id in by_case:
            raise ValueError(f"Duplicate benchmark case result: {case_id}")

        case = cases_by_id[case_id]
        score = float(item["score"])
        if not 0.0 <= score <= 1.0:
            raise ValueError(f"score must be between 0 and 1 for {case_id}")

        by_case[case_id] = {
            "case_id": case_id,
            "kind": case["kind"],
            "weight": case["weight"],
            "pass": bool(item["pass"]),
            "score": score,
            "false_trigger": bool(item.get("false_trigger", False)),
            "safety_regression": bool(item.get("safety_regression", False)),
            "notes": normalize_notes(item.get("notes")),
        }

    missing = sorted(set(cases_by_id).difference(by_case))
    if missing:
        raise ValueError(f"Missing benchmark case results: {', '.join(missing)}")

    return [by_case[case_id] for case_id in cases_by_id]


def normalize_evaluation_result(
    raw_payload: dict[str, Any],
    label: str,
    target_skill_dir: Path,
    cases: list[dict[str, Any]],
) -> dict[str, Any]:
    if "case_results" not in raw_payload:
        raise ValueError("Evaluation output must include case_results.")

    cases_by_id = {case["case_id"]: case for case in cases}
    case_results = normalize_case_results(raw_payload["case_results"], cases_by_id)

    weighted_total = sum(result["score"] * result["weight"] for result in case_results)
    total_weight = sum(result["weight"] for result in case_results)
    weighted_mean_score = round(weighted_total / total_weight, 6)
    negative_false_triggers = sum(
        1 for result in case_results if result["kind"] == "negative" and result["false_trigger"]
    )
    safety_regressions = sum(
        1
        for result in case_results
        if result["kind"] == "safety" and result["safety_regression"]
    )

    return {
        "label": str(raw_payload.get("label", label)),
        "skill_path": str(raw_payload.get("skill_path", target_skill_dir)),
        "weighted_mean_score": weighted_mean_score,
        "negative_false_triggers": negative_false_triggers,
        "safety_regressions": safety_regressions,
        "case_results": case_results,
        "summary": normalize_notes(raw_payload.get("summary")),
    }


def validate_mutation_result(raw_payload: dict[str, Any], run_id: str, candidates: dict[str, Path]) -> dict[str, Any]:
    notes = normalize_notes(raw_payload.get("notes"))
    normalized_candidates = []
    for label, path in candidates.items():
        hypothesis_file = path / "HYPOTHESIS.md"
        if not hypothesis_file.exists():
            raise FileNotFoundError(f"Mutation run did not create {hypothesis_file}")
        normalized_candidates.append(
            {
                "name": label,
                "path": str(path),
                "hypothesis_file": str(hypothesis_file),
            }
        )

    return {
        "run_id": str(raw_payload.get("run_id", run_id)),
        "candidates": normalized_candidates,
        "notes": notes,
    }


def collect_regressions(
    candidate_name: str, baseline_eval: dict[str, Any], candidate_eval: dict[str, Any]
) -> list[dict[str, str]]:
    baseline_by_case = {item["case_id"]: item for item in baseline_eval["case_results"]}
    regressions: list[dict[str, str]] = []
    for result in candidate_eval["case_results"]:
        baseline_case = baseline_by_case[result["case_id"]]
        if result["kind"] == "negative" and result["false_trigger"] and not baseline_case["false_trigger"]:
            regressions.append(
                {
                    "candidate": candidate_name,
                    "case_id": result["case_id"],
                    "issue": "negative_false_trigger_increase",
                    "notes": "; ".join(result["notes"]) or "Candidate forced a negative case in scope.",
                }
            )
        if result["kind"] == "safety" and result["safety_regression"]:
            regressions.append(
                {
                    "candidate": candidate_name,
                    "case_id": result["case_id"],
                    "issue": "safety_regression",
                    "notes": "; ".join(result["notes"]) or "Candidate under-handled a safety case.",
                }
            )
    return regressions


def gate_candidate(
    baseline_eval: dict[str, Any],
    candidate_eval: dict[str, Any],
    skill_md_bytes: int,
    baseline_skill_md_bytes: int,
) -> tuple[bool, list[str]]:
    failures: list[str] = []
    score_delta = candidate_eval["weighted_mean_score"] - baseline_eval["weighted_mean_score"]
    growth_ratio = 0.0
    if baseline_skill_md_bytes > 0:
        growth_ratio = (skill_md_bytes - baseline_skill_md_bytes) / baseline_skill_md_bytes

    if score_delta < 0.03:
        failures.append("mean_score_below_promotion_margin")
    if candidate_eval["negative_false_triggers"] > baseline_eval["negative_false_triggers"]:
        failures.append("negative_false_trigger_increase")
    if candidate_eval["safety_regressions"] > 0:
        failures.append("safety_regression")
    if growth_ratio > 0.15 and score_delta < 0.05:
        failures.append("skill_growth_without_extra_gain")

    return (not failures, failures)


def candidate_summary(
    name: str,
    path: Path,
    baseline_eval: dict[str, Any],
    candidate_eval: dict[str, Any],
    baseline_skill_md_bytes: int,
) -> tuple[dict[str, Any], list[dict[str, str]]]:
    skill_md_bytes = (path / "SKILL.md").stat().st_size
    growth_ratio = 0.0
    if baseline_skill_md_bytes > 0:
        growth_ratio = round((skill_md_bytes - baseline_skill_md_bytes) / baseline_skill_md_bytes, 6)

    passes_gate, failures = gate_candidate(
        baseline_eval=baseline_eval,
        candidate_eval=candidate_eval,
        skill_md_bytes=skill_md_bytes,
        baseline_skill_md_bytes=baseline_skill_md_bytes,
    )
    regressions = collect_regressions(name, baseline_eval, candidate_eval)
    summary = {
        "name": name,
        "path": str(path),
        "mean_score": candidate_eval["weighted_mean_score"],
        "negative_false_triggers": candidate_eval["negative_false_triggers"],
        "safety_regressions": candidate_eval["safety_regressions"],
        "skill_md_bytes": skill_md_bytes,
        "skill_md_growth_ratio": growth_ratio,
        "passes_gate": passes_gate,
        "gate_failures": failures,
        "case_results": candidate_eval["case_results"],
    }
    return summary, regressions


def choose_best_candidate(candidates: list[dict[str, Any]]) -> dict[str, Any]:
    return sorted(
        candidates,
        key=lambda item: (
            item["mean_score"],
            -item["negative_false_triggers"],
            -item["safety_regressions"],
            -item["skill_md_growth_ratio"],
            -item["skill_md_bytes"],
        ),
        reverse=True,
    )[0]


def sync_tree(source: Path, destination: Path, top_level_excludes: set[str]) -> None:
    source_names = {item.name for item in source.iterdir()}
    for target in list(destination.iterdir()):
        if target.name in top_level_excludes:
            continue
        if target.name not in source_names:
            if target.is_dir():
                shutil.rmtree(target)
            else:
                target.unlink()

    for source_child in source.iterdir():
        if source_child.name in top_level_excludes:
            continue
        destination_child = destination / source_child.name
        if source_child.is_dir():
            if destination_child.exists() and not destination_child.is_dir():
                destination_child.unlink()
            destination_child.mkdir(parents=True, exist_ok=True)
            sync_tree(source_child, destination_child, set())
        else:
            destination_child.parent.mkdir(parents=True, exist_ok=True)
            shutil.copy2(source_child, destination_child)


def promote_candidate(candidate_dir: Path, destination_dir: Path, workspace: Workspace) -> None:
    if destination_dir.resolve() == workspace.root.resolve():
        sync_tree(candidate_dir, destination_dir, ROOT_SKILL_EXCLUDES)
        return

    staging_dir = destination_dir.parent / f".{destination_dir.name}.promote-staging"
    backup_dir = destination_dir.parent / f".{destination_dir.name}.backup"

    if staging_dir.exists():
        shutil.rmtree(staging_dir)
    if backup_dir.exists():
        shutil.rmtree(backup_dir)

    shutil.copytree(candidate_dir, staging_dir, ignore=shutil.ignore_patterns("HYPOTHESIS.md"))
    destination_dir.rename(backup_dir)
    staging_dir.rename(destination_dir)
    shutil.rmtree(backup_dir)


def repository_has_commits(workspace: Workspace) -> bool:
    completed = subprocess.run(
        ["git", "rev-parse", "--verify", "HEAD"],
        cwd=workspace.root,
        check=False,
        capture_output=True,
        text=True,
    )
    return completed.returncode == 0


def update_leaderboard(
    workspace: Workspace,
    run_id: str,
    mode: str,
    final_payload: dict[str, Any],
) -> None:
    leaderboard = json.loads(workspace.leaderboard_path.read_text(encoding="utf-8"))
    history = leaderboard.setdefault("history", [])
    history.append(
        {
            "run_id": run_id,
            "mode": mode,
            "baseline_score": final_payload["baseline_score"],
            "winner": final_payload["winner"],
            "promote": final_payload["promote"],
            "winning_candidate_path": final_payload["winning_candidate_path"],
            "regressions": final_payload["regressions"],
        }
    )
    leaderboard["last_run_id"] = run_id
    if final_payload["promote"]:
        winner_name = final_payload["winner"]
        winning_candidate = next(
            candidate for candidate in final_payload["candidates"] if candidate["name"] == winner_name
        )
        leaderboard["best_promoted_score"] = winning_candidate["mean_score"]

    write_json(workspace.leaderboard_path, leaderboard)


def validate_final_payload(payload: dict[str, Any]) -> None:
    missing = FINAL_REQUIRED_KEYS.difference(payload)
    if missing:
        raise ValueError(f"Final payload missing keys: {', '.join(sorted(missing))}")
    if len(payload["candidates"]) != 2:
        raise ValueError("Final payload must contain exactly two candidates.")


def run_iteration(
    workspace: Workspace,
    mode: str,
    run_id: str | None = None,
    executor: Executor = invoke_codex_exec,
) -> dict[str, Any]:
    ensure_required_paths(workspace)
    cases = load_cases(workspace)
    run_id = run_id or create_run_id()
    run_dir, candidate_root = prepare_run_directories(workspace, run_id)
    candidates = prepare_candidate_copies(workspace, candidate_root)

    mutation_prompt = render_root_prompt(workspace, "mutation", run_id)
    mutation_raw_path = run_dir / "mutation_raw.json"
    mutation_raw = executor(
        workspace,
        mutation_prompt,
        "autoresearch_mutate",
        "workspace-write",
        mutation_raw_path,
        None,
        {"AUTORESEARCH_HOOK_MODE": "mutation"},
        None,
    )
    mutation_result = validate_mutation_result(mutation_raw, run_id, candidates)
    write_json(run_dir / "mutation.json", mutation_result)

    baseline_skill_md_bytes = (workspace.skill_dir / "SKILL.md").stat().st_size
    baseline_prompt = render_root_prompt(
        workspace,
        "evaluation",
        run_id,
        extra_context=(
            "- evaluation_label: baseline\n"
            f"- target_skill_path: {workspace.skill_dir}\n"
            "- Return JSON only."
        ),
    )
    baseline_raw = executor(
        workspace,
        baseline_prompt,
        "autoresearch_eval",
        "read-only",
        run_dir / "baseline_eval_raw.json",
        [],
        {"AUTORESEARCH_HOOK_MODE": "evaluation", "AUTORESEARCH_EVAL_LABEL": "baseline"},
        None,
    )
    baseline_eval = normalize_evaluation_result(
        baseline_raw,
        label="baseline",
        target_skill_dir=workspace.skill_dir,
        cases=cases,
    )
    write_json(run_dir / "baseline_eval.json", baseline_eval)

    candidate_payloads: list[dict[str, Any]] = []
    regressions: list[dict[str, str]] = []
    for name, path in candidates.items():
        prompt = render_root_prompt(
            workspace,
            "evaluation",
            run_id,
            extra_context=(
                f"- evaluation_label: {name}\n"
                f"- target_skill_path: {path}\n"
                "- Return JSON only."
            ),
        )
        raw_eval = executor(
            workspace,
            prompt,
            "autoresearch_eval",
            "read-only",
            run_dir / f"{name}_eval_raw.json",
            build_skill_override(workspace, path),
            {"AUTORESEARCH_HOOK_MODE": "evaluation", "AUTORESEARCH_EVAL_LABEL": name},
            None,
        )
        normalized_eval = normalize_evaluation_result(raw_eval, label=name, target_skill_dir=path, cases=cases)
        write_json(run_dir / f"{name}_eval.json", normalized_eval)

        summary, candidate_regressions = candidate_summary(
            name=name,
            path=path,
            baseline_eval=baseline_eval,
            candidate_eval=normalized_eval,
            baseline_skill_md_bytes=baseline_skill_md_bytes,
        )
        candidate_payloads.append(summary)
        regressions.extend(candidate_regressions)

    best_candidate = choose_best_candidate(candidate_payloads)
    promote = best_candidate["passes_gate"]
    winning_candidate_path = best_candidate["path"] if promote else None
    winner = best_candidate["name"] if promote else "baseline"

    notes = mutation_result["notes"][:]
    if not repository_has_commits(workspace):
        notes.append("Git worktree automations require at least one commit in this repository.")
    notes.append(f"Mode: {mode}")
    notes.append(f"Best candidate score delta: {round(best_candidate['mean_score'] - baseline_eval['weighted_mean_score'], 6)}")

    if promote:
        promote_candidate(Path(best_candidate["path"]), workspace.skill_dir, workspace)

    final_payload = {
        "run_id": run_id,
        "baseline_score": baseline_eval["weighted_mean_score"],
        "candidates": candidate_payloads,
        "winner": winner,
        "promote": promote,
        "winning_candidate_path": winning_candidate_path,
        "regressions": regressions,
        "notes": notes,
    }
    validate_final_payload(final_payload)
    write_json(run_dir / "final.json", final_payload)
    update_leaderboard(workspace, run_id, mode, final_payload)
    return final_payload


def main() -> int:
    args = parse_args()
    workspace = build_workspace()
    payload = run_iteration(workspace, mode=args.mode, run_id=args.run_id)
    print(json.dumps(payload, indent=2))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
