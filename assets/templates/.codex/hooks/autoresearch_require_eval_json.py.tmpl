#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import sys


REQUIRED_KEYS = {
    "label",
    "skill_path",
    "weighted_mean_score",
    "negative_false_triggers",
    "safety_regressions",
    "case_results",
    "summary",
}


def main() -> int:
    payload = json.load(sys.stdin)

    if os.environ.get("AUTORESEARCH_HOOK_MODE") != "evaluation":
        print(json.dumps({"continue": True}))
        return 0

    if payload.get("stop_hook_active"):
        print(json.dumps({"continue": True}))
        return 0

    last_message = payload.get("last_assistant_message")
    if not last_message:
        print(
            json.dumps(
                {
                    "decision": "block",
                    "reason": (
                        "Return one more message with evaluator JSON only. "
                        "Include label, skill_path, weighted_mean_score, "
                        "negative_false_triggers, safety_regressions, case_results, and summary."
                    ),
                }
            )
        )
        return 0

    try:
        parsed = json.loads(last_message)
    except json.JSONDecodeError:
        print(
            json.dumps(
                {
                    "decision": "block",
                    "reason": (
                        "Return evaluator output as raw JSON only with the required top-level keys."
                    ),
                }
            )
        )
        return 0

    missing = sorted(REQUIRED_KEYS.difference(parsed))
    if missing or not isinstance(parsed.get("case_results"), list) or not parsed["case_results"]:
        reason = (
            "Return one more message with valid evaluator JSON. Missing or invalid keys: "
            + ", ".join(missing or ["case_results"])
        )
        print(json.dumps({"decision": "block", "reason": reason}))
        return 0

    print(json.dumps({"continue": True}))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
